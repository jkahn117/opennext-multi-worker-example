{
  "name": "@opennext-shop/middleware",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=esm --external:cloudflare:workers",
    "dev": "wrangler dev --config wrangler.jsonc --local",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opennext-shop/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
